{
  "name": "crime-analysis",
  "version": "1.0.0",
  "description": "Crime Analysis Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && SET NODE_ENV=development && electron .\"",
    "build:renderer": "vite build",
    "build": "vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "svelte": "^4.2.12",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.crime-analysis.app",
    "productName": "Crime Analysis System",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": ["node_modules/better-sqlite3/**"],
    "linux": { "target": ["AppImage", "deb"], "category": "Utility" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" }
  }
}
